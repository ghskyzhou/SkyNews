# Copy this file to backend/.env.
# Keep real secrets in backend/.env only. Never expose these values to the frontend.
TAVILY_API_KEY=
DEEPSEEK_API_KEY=

# DeepSeek API is OpenAI-compatible, but SkyNews calls it through httpx directly.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=12000
DEEPSEEK_MAX_BRIEF_ITEMS=8

# Cost controls. Defaults search only one query per tag with a few results.
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_QUERIES_PER_TAG=1
TAVILY_MAX_RESULTS_PER_QUERY=3
API_TIMEOUT_SECONDS=90

# true/false. If true, or if TAVILY_API_KEY is empty, SkyNews uses local mock data.
MOCK_MODE=false

# Optional override. Defaults to backend/data/skynews.db.
SKYNEWS_DB_PATH=

# Comma-separated stock tickers shown at the bottom of the page.
STOCK_SYMBOLS=QQQ,VOO,DRAM,MU,NVDA
